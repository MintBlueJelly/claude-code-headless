{
  "autoUpdatesChannel": "stable",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Glob",
      "Grep",
      "Read",
      "Bash(dig:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(host:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(kubectl auth:*)",
      "Bash(kubectl config view:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl version:*)",
      "Bash(nslookup:*)",
      "Bash(omnictl get:*)",
      "Bash(talosctl dmesg:*)",
      "Bash(talosctl get:*)",
      "Bash(talosctl health:*)",
      "Bash(talosctl list:*)",
      "Bash(talosctl logs:*)",
      "Bash(talosctl read:*)",
      "Bash(talosctl services:*)",
      "Bash(talosctl version:*)",
      "mcp__kubernetes-mcp-server",
      "mcp__openobserve__GetIncident",
      "mcp__openobserve__PrometheusRangeQuery",
      "mcp__openobserve__SearchSQL",
      "mcp__openobserve__StreamList",
      "mcp__openobserve__StreamSchema",
      "mcp__openobserve__tool_search",
      "mcp__siderolabs-docs",
      "mcp__technitium-ns1",
      "mcp__technitium-ns2"
    ],
    "disableBypassPermissionsMode": "disable"
  }
}
